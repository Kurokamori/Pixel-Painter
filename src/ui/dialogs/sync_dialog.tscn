[node name="Layout" type="VBoxContainer" parent="."]
offset_left = 12.0
offset_top = 12.0
offset_right = 508.0
offset_bottom = 404.0
theme_override_constants/separation = 10

[node name="DeviceRow" type="HBoxContainer" parent="Layout"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="Label" type="Label" parent="Layout/DeviceRow"]
layout_mode = 2
text = "This device"
vertical_alignment = 1

[node name="DeviceNameEdit" type="LineEdit" parent="Layout/DeviceRow"]
unique_name_in_owner = true
custom_minimum_size = Vector2(0, 40)

[node name="Peers" type="VBoxContainer" parent="Layout/Scroll"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 4

[node name="EmptyLabel" type="Label" parent="Layout/Scroll/Peers"]
unique_name_in_owner = true

[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://src/ui/dialogs/pp_sync_dialog.gd" id="1_script"]

[node name="SyncDialog" type="AcceptDialog"]
title = "Sync"
initial_position = 2
size = Vector2i(520, 460)
